# ============================================
# Trenvus - DEVELOPMENT Environment
# ============================================
# Este arquivo é SEGURO para commitar (apenas desenvolvimento local)
# Em produção, usar .env com chaves diferentes e REVOGAR estas!

POSTGRES_DB=exchange
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Spring Database Configuration (REQUIRED for Docker)
SPRING_DATASOURCE_URL=jdbc:postgresql://db:5432/exchange
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=postgres

# JWT Keys (DESENVOLVIMENTO APENAS - não use em produção!)
JWT_ISSUER=Trenvus
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000
JWT_PRIVATE_KEY_
JWT_PUBLIC_KEY_

# CORS
APP_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173

# URLs
APP_BASE_URL=http://localhost:3000
API_BASE_URL=http://localhost:8080

# SMTP (vazio para dev)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=noreply@trenvus.com

# Mercado Pago (token de teste para dev - não é válido em produção)
MERCADOPAGO_ACCESS_TOKEN=TEST-0000000000000000-000000-00000000000000000000000000000000-000000000
MERCADOPAGO_PUBLIC_KEY=TEST-00000000-0000-0000-0000-000000000000
MERCADOPAGO_RETURN_URL=http://localhost:3000/mercadopago/return

# Test Accounts (habilitado para dev)
TEST_ACCOUNT_ENABLED=true
TEST_ACCOUNTS=user1@test.com:123:USER;user2@test.com:123:USER;user3@test.com:123:USER
ADMIN_ACCOUNT_ENABLED=true
ADMIN_LOGIN_ENABLED=true
ADMIN_EMAIL=admin@trenvus.com
ADMIN_PASSWORD=admin123

# Market
MARKET_ASSETS=BTC,ETH,USDT,SOL,ADA,DOT
MARKET_CACHE_TTL_SECONDS=60

# Security
ALLOWED_ORIGINS=*
