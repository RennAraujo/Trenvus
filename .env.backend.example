# ============================================
# Trenvus - Environment Configuration Template
# ============================================
# Copie este arquivo para .env.backend e configure suas variáveis
# NUNCA commite o arquivo .env.backend (contém credenciais)

# Database Configuration
POSTGRES_DB=exchange
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_IN_PRODUCTION

# Spring Database Configuration
SPRING_DATASOURCE_URL=jdbc:postgresql://db:5432/exchange
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=CHANGE_ME_IN_PRODUCTION

# JWT Keys (GERAR NOVAS PARA PRODUÇÃO!)
# Use: openssl genrsa -out private.pem 2048
#      openssl rsa -in private.pem -pubout -out public.pem
#      base64 -w 0 private.pem
#      base64 -w 0 public.pem
JWT_ISSUER=Trenvus
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000
JWT_PRIVATE_KEY_B64=YOUR_PRIVATE_KEY_HERE
JWT_PUBLIC_KEY_B64=YOUR_PUBLIC_KEY_HERE

# CORS - Configure para seu domínio
APP_CORS_ORIGINS=http://localhost:3000,http://195.200.7.31:3000

# URLs - Configure para seu ambiente
APP_BASE_URL=http://195.200.7.31:3000
API_BASE_URL=http://195.200.7.31:8080

# SMTP Configuration (para envio de emails)
SMTP_ENABLED=true
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@trenvus.com

# Mercado Pago Configuration
# Obtenha em: https://www.mercadopago.com.br/developers
MERCADOPAGO_ACCESS_TOKEN=YOUR_MP_ACCESS_TOKEN
MERCADOPAGO_PUBLIC_KEY=YOUR_MP_PUBLIC_KEY
MERCADOPAGO_RETURN_URL=http://195.200.7.31:3000/mercadopago/return

# Test Accounts (desabilitar em produção!)
TEST_ACCOUNT_ENABLED=false
TEST_ACCOUNTS=

# Admin Account
ADMIN_ACCOUNT_ENABLED=true
ADMIN_LOGIN_ENABLED=true
ADMIN_EMAIL=admin@trenvus.com
ADMIN_PASSWORD=CHANGE_THIS_PASSWORD

# Market Data Configuration
MARKET_ASSETS=BTC,ETH,USDT
MARKET_CACHE_TTL_SECONDS=60

# Security
ALLOWED_ORIGINS=*
