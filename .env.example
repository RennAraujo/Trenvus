# ============================================
# Trenvus - Environment Configuration
# ============================================
# Copie este arquivo para .env e configure suas variáveis
# NUNCA commite o arquivo .env real!

# ============================================
# Database Configuration
# ============================================
POSTGRES_DB=exchange
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# ============================================
# JWT Configuration (REQUIRED)
# ============================================
# Gere as chaves com: ./generate-jwt-keys.sh
# Ou use valores Base64 de chaves RSA
JWT_ISSUER=Trenvus
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000
JWT_PRIVATE_KEY_B64=
JWT_PUBLIC_KEY_B64=

# ============================================
# CORS Configuration
# ============================================
APP_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173

# ============================================
# Application URLs
# ============================================
APP_BASE_URL=http://localhost:3000
API_BASE_URL=http://localhost:8080

# ============================================
# SMTP Configuration (Email)
# ============================================
# Para Gmail: use App Password (não a senha normal)
# https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=noreply@trenvus.com

# ============================================
# Mercado Pago Configuration
# ============================================
# Obtenha em: https://www.mercadopago.com.br/developers
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_PUBLIC_KEY=
MERCADOPAGO_RETURN_URL=http://localhost:3000/mercadopago/return

# ============================================
# Test Accounts Configuration
# ============================================
# Habilita criação automática de contas de teste no startup
TEST_ACCOUNT_ENABLED=true

# Formato: email:senha:role;email:senha:role
# Roles disponíveis: USER, ADMIN
TEST_ACCOUNTS=user1@test.com:123:USER;user2@test.com:123:USER;user3@test.com:123:USER

# Conta admin (se ADMIN_ACCOUNT_ENABLED=true)
ADMIN_ACCOUNT_ENABLED=true
ADMIN_LOGIN_ENABLED=true
ADMIN_EMAIL=admin@trenvus.com
ADMIN_PASSWORD=admin123

# ============================================
# Market/Exchange Configuration
# ============================================
MARKET_ASSETS=BTC,ETH,USDT,SOL,ADA,DOT
MARKET_CACHE_TTL_SECONDS=60

# ============================================
# Security Settings
# ============================================
# Em produção, defina como false
ALLOWED_ORIGINS=*
